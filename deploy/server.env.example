# Void Dominion VPS server config — copy to deploy/server.env and fill in.
#   cp deploy/server.env.example deploy/server.env
# deploy/server.env is gitignored, so your token stays on the server only.

# Port to serve on. 8788 is the default; use 80 so players can drop the ":8788"
# (port 80 needs root, which you have on the VPS).
PORT=8788

# Playtest fast-forward: wall→game clock multiplier so a real minute is many game-hours
# (fleets/builds/economy resolve on-screen instead of over real hours). 1 = real-time;
# 200 ≈ a real minute is ~3.3 game-hours. Only affects the live clock, not the rules.
TIME_SCALE=200

# Durable matches (optional): point at a Postgres and the match survives a server
# restart (the server snapshots state to it and resumes on boot). Bring Postgres up
# with `cd deploy && docker compose up -d`, then uncomment:
# DATABASE_URL=postgres://void:void@127.0.0.1:5432/void
# Leave it unset to keep the match in-memory (a restart loses it).

# Optional auto-update credential. PREFERRED: leave this BLANK and instead point
# the repo at a read-only SSH deploy key (no reusable secret on the box):
#   ssh-keygen -t ed25519 -f ~/.ssh/nygame_deploy -N ""
#   # add ~/.ssh/nygame_deploy.pub as a read-only Deploy key on the GitHub repo
#   git remote set-url origin git@github.com:Moonwuk/Nygame.git
# Then `pnpm serve` pulls over SSH with no token anywhere.
#
# Fallback only: a GitHub token with read access to Moonwuk/Nygame. If set, serve.sh
# pulls over HTTPS using it (fed via GIT_ASKPASS, never the URL/argv). This file is
# gitignored so the token is never committed — but a deploy key is still safer.
GIT_TOKEN=
