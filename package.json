{
  "name": "void-dominion",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "author": "Moonwuk Games",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r --if-present run typecheck",
    "prototype": "node prototype/build.mjs",
    "dev:server": "node packages/server/dev.mjs",
    "dev:proto-server": "node prototype/netserver.mjs",
    "host": "node prototype/host.mjs",
    "serve": "bash deploy/serve.sh",
    "stack": "docker compose -f deploy/docker-compose.yml up -d --build",
    "doctor": "node prototype/doctor.mjs",
    "perf": "node prototype/perf.mjs",
    "metrics": "node prototype/report.mjs",
    "selfplay": "node prototype/selfplay.mjs",
    "dev:client": "node testclient/build.mjs",
    "audit": "pnpm audit --audit-level=high",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run docs-check",
    "docs-check": "node scripts/docs-check.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "fast-check": "^4.9.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "overrides": {
      "fast-uri@3": "3.1.4",
      "fast-uri@4": "4.1.1",
      "find-my-way@9": "^9.7.0"
    }
  }
}
