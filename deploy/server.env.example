# Void Dominion VPS server config — copy to deploy/server.env and fill in.
#   cp deploy/server.env.example deploy/server.env
# deploy/server.env is gitignored, so your token stays on the server only.

# Port to serve on. 8788 is the default; use 80 so players can drop the ":8788"
# (port 80 needs root, which you have on the VPS).
PORT=8788

# Optional: a GitHub token with read access to Moonwuk/Nygame. If set, `bash
# deploy/serve.sh` will `git pull` the latest code before each restart, so you
# don't retype it. Leave blank to skip auto-update (just serves the local code).
GIT_TOKEN=
